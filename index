import React, { useState, useEffect, useMemo } from 'react';
import { Search, Printer, FileText, Upload, User, GraduationCap, Clock, Calendar } from 'lucide-react';

const App = () => {
  const [data, setData] = useState([]);
  const [searchTerm, setSearchTerm] = useState('');
  const [selectedStudent, setSelectedStudent] = useState(null);
  const [professor, setProfessor] = useState('');
  const [currentDate, setCurrentDate] = useState(new Date().toLocaleDateString('pt-BR'));

  // Função para processar o CSV enviado pelo usuário
  const handleFileUpload = (event) => {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (e) => {
      const text = e.target.result;
      const lines = text.split(/\r?\n/);
      if (lines.length < 2) return;

      const headers = lines[0].split(';');
      const result = [];

      for (let i = 1; i < lines.length; i++) {
        if (!lines[i].trim()) continue;
        const currentline = lines[i].split(';');
        const obj = {};
        headers.forEach((header, index) => {
          obj[header.trim()] = currentline[index]?.trim();
        });
        result.push(obj);
      }
      setData(result);
      // Salva no localStorage para não precisar subir toda vez
      localStorage.setItem('studentData', JSON.stringify(result));
    };
    reader.readAsText(file);
  };

  // Carrega dados salvos anteriormente
  useEffect(() => {
    const saved = localStorage.getItem('studentData');
    if (saved) {
      setData(JSON.parse(saved));
    }
  }, []);

  // Filtragem de alunos
  const filteredStudents = useMemo(() => {
    if (!searchTerm) return [];
    return data.filter(s => 
      s.Aluno?.toLowerCase().includes(searchTerm.toLowerCase())
    ).slice(0, 10);
  }, [searchTerm, data]);

  const handlePrint = () => {
    window.print();
  };

  return (
    <div className="min-h-screen bg-gray-50 flex flex-col items-center p-4 sm:p-8 font-sans">
      
      {/* SEÇÃO DE CONTROLE (Oculta na Impressão) */}
      <div className="print:hidden w-full max-w-4xl space-y-6 bg-white p-6 rounded-2xl shadow-sm mb-8 border border-gray-100">
        <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h1 className="text-2xl font-bold text-gray-800 flex items-center gap-2">
              <FileText className="text-blue-600" />
              Automação de Transferência
            </h1>
            <p className="text-gray-500 text-sm">Escola Municipal Walda Miranda de Paiva</p>
          </div>
          
          <label className="flex items-center gap-2 px-4 py-2 bg-blue-50 text-blue-700 rounded-lg cursor-pointer hover:bg-blue-100 transition-colors border border-blue-200 text-sm font-medium">
            <Upload size={18} />
            Importar CUBO.CSV
            <input type="file" accept=".csv" onChange={handleFileUpload} className="hidden" />
          </label>
        </div>

        <div className="relative group">
          <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400 group-focus-within:text-blue-500 transition-colors">
            <Search size={20} />
          </div>
          <input
            type="text"
            className="block w-full pl-10 pr-3 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none"
            placeholder="Pesquise pelo nome do aluno..."
            value={searchTerm}
            onChange={(e) => setSearchTerm(e.target.value)}
          />

          {/* Sugestões */}
          {filteredStudents.length > 0 && !selectedStudent && (
            <div className="absolute z-10 w-full mt-2 bg-white border border-gray-200 rounded-xl shadow-lg overflow-hidden">
              {filteredStudents.map((student, idx) => (
                <button
                  key={idx}
                  onClick={() => {
                    setSelectedStudent(student);
                    setSearchTerm(student.Aluno);
                  }}
                  className="w-full text-left px-4 py-3 hover:bg-blue-50 flex items-center justify-between transition-colors border-b last:border-0 border-gray-100"
                >
                  <span className="font-medium text-gray-700">{student.Aluno}</span>
                  <span className="text-xs text-gray-400">{student.Ano} - {student.Turma}</span>
                </button>
              ))}
            </div>
          )}
        </div>

        {selectedStudent && (
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4 animate-in fade-in slide-in-from-top-2 duration-300">
            <div className="space-y-1">
              <label className="text-xs font-semibold text-gray-400 uppercase tracking-wider">Professor(a)</label>
              <input
                type="text"
                className="w-full p-2 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
                placeholder="Nome do Professor(a)"
                value={professor}
                onChange={(e) => setProfessor(e.target.value)}
              />
            </div>
            <div className="space-y-1">
              <label className="text-xs font-semibold text-gray-400 uppercase tracking-wider">Data do Documento</label>
              <input
                type="text"
                className="w-full p-2 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
                value={currentDate}
                onChange={(e) => setCurrentDate(e.target.value)}
              />
            </div>
            <div className="md:col-span-2 flex justify-end gap-3 mt-2">
              <button
                onClick={() => {setSelectedStudent(null); setSearchTerm('');}}
                className="px-4 py-2 text-gray-500 hover:text-gray-700 font-medium"
              >
                Limpar
              </button>
              <button
                onClick={handlePrint}
                className="flex items-center gap-2 px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 shadow-md transition-all font-semibold"
              >
                <Printer size={18} />
                Imprimir Requerimento
              </button>
            </div>
          </div>
        )}

        {!selectedStudent && data.length === 0 && (
          <div className="text-center py-10 bg-blue-50 rounded-xl border-2 border-dashed border-blue-200">
            <Upload className="mx-auto text-blue-300 mb-2" size={40} />
            <p className="text-blue-800 font-medium">Por favor, importe o arquivo CUBO.CSV para começar.</p>
          </div>
        )}
      </div>

      {/* DOCUMENTO PARA IMPRESSÃO */}
      <div className={`print:shadow-none bg-white shadow-xl w-[210mm] min-h-[297mm] p-[20mm] flex flex-col text-black font-serif relative ${!selectedStudent ? 'opacity-30 pointer-events-none' : ''}`}>
        
        {/* Marca d'água de ajuda (oculta na impressão) */}
        {!selectedStudent && (
          <div className="absolute inset-0 flex items-center justify-center print:hidden">
            <span className="text-4xl text-gray-200 font-sans font-bold -rotate-45">PRE-VISUALIZAÇÃO</span>
          </div>
        )}

        {/* Cabeçalho */}
        <div className="text-center mb-8">
          <h1 className="text-2xl font-bold uppercase underline">Requerimento de Transferência</h1>
          <div className="mt-8 space-y-1">
            <h2 className="text-xl font-bold">ESCOLA MUNICIPAL WALDA MIRANDA DE PAIVA</h2>
          </div>
        </div>

        {/* Nome do Aluno */}
        <div className="mb-6">
          <div className="flex flex-col">
            <span className="text-sm font-bold">NOME DO ALUNO</span>
            <div className="border-b-2 border-black py-2 px-4 text-xl h-10 flex items-end">
              {selectedStudent?.Aluno || ''}
            </div>
          </div>
        </div>

        {/* Grid de Informações */}
        <div className="grid grid-cols-5 gap-4 mb-8">
          <div className="col-span-1 border-b-2 border-black pb-1">
            <span className="text-xs font-bold block">Ano:</span>
            <div className="text-center mt-2">{selectedStudent?.Ano ? selectedStudent.Ano.split('°')[0] : '______'}</div>
          </div>
          <div className="col-span-1 border-b-2 border-black pb-1">
            <span className="text-xs font-bold block">Série:</span>
            <div className="text-center mt-2">{selectedStudent?.Ano || '____'}</div>
          </div>
          <div className="col-span-1 border-b-2 border-black pb-1">
            <span className="text-xs font-bold block">Turma:</span>
            <div className="text-center mt-2">{selectedStudent?.Turma || '____'}</div>
          </div>
          <div className="col-span-1 border-b-2 border-black pb-1">
            <span className="text-xs font-bold block">Turno:</span>
            <div className="text-center mt-2">{selectedStudent?.Turno || '________'}</div>
          </div>
          <div className="col-span-1 border-b-2 border-black pb-1">
            <span className="text-xs font-bold block">Ano Letivo:</span>
            <div className="text-center mt-2">{selectedStudent?.['Ano Letivo'] || '________'}</div>
          </div>
        </div>

        {/* Professor */}
        <div className="mb-12">
          <div className="flex items-center gap-2">
            <span className="text-sm font-bold whitespace-nowrap">Prof. (a):</span>
            <div className="border-b border-black w-full text-lg min-h-[30px]">
              {professor}
            </div>
          </div>
        </div>

        {/* Corpo */}
        <div className="text-center mb-16 mt-4">
          <h3 className="text-2xl font-bold italic">Requer sua Transferência</h3>
        </div>

        {/* Assinaturas e Datas */}
        <div className="space-y-16">
          <div className="flex items-end gap-4">
            <div className="w-1/3 border-b border-black flex items-center justify-between pb-1">
              <span className="text-sm font-bold">Data:</span>
              <span>{currentDate}</span>
            </div>
            <div className="w-2/3 flex flex-col items-center">
              <div className="w-full border-b border-black"></div>
              <span className="text-[10px] font-bold mt-1 uppercase text-center">ASSINATURA DO ALUNO OU RESPONSÁVEL</span>
            </div>
          </div>

          <div className="flex items-end gap-4">
            <div className="w-1/3 border-b border-black flex items-center justify-between pb-1">
              <span className="text-sm font-bold">Data:</span>
              <span>____/____/____</span>
            </div>
            <div className="w-2/3 flex flex-col items-center">
              <div className="w-full border-b border-black"></div>
              <span className="text-[10px] font-bold mt-1 uppercase text-center">RECEBI A DOCUMENTAÇÃO</span>
            </div>
          </div>
        </div>

        {/* Deferimento */}
        <div className="mt-auto pt-20">
          <div className="max-w-md mx-auto flex flex-col items-center">
            <div className="w-full border-b-2 border-black"></div>
            <span className="text-xs font-bold mt-1 uppercase">DEFERIMENTO DO DIRETOR/SECRETÁRIO</span>
          </div>
        </div>

        {/* Rodapé Oficial */}
        <div className="mt-12 text-center space-y-1 border-t pt-4">
          <p className="text-sm font-bold uppercase tracking-widest">ESTADO DE GOIÁS</p>
          <p className="text-sm font-bold uppercase tracking-widest">PREFEITURA MUNICIPAL DE FORMOSA</p>
          <p className="text-sm font-bold uppercase tracking-widest">SECRETARIA MUNICIPAL DE EDUCAÇÃO</p>
        </div>
      </div>

      {/* Instruções de Uso (ocultas na impressão) */}
      <div className="print:hidden w-full max-w-4xl mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 text-gray-400 text-xs">
        <div className="flex items-center gap-2 bg-white p-3 rounded-lg border border-gray-100">
          <div className="bg-blue-50 p-2 rounded-full"><Upload size={14} className="text-blue-500"/></div>
          <span>1. Suba o arquivo CSV</span>
        </div>
        <div className="flex items-center gap-2 bg-white p-3 rounded-lg border border-gray-100">
          <div className="bg-blue-50 p-2 rounded-full"><User size={14} className="text-blue-500"/></div>
          <span>2. Procure o aluno pelo nome</span>
        </div>
        <div className="flex items-center gap-2 bg-white p-3 rounded-lg border border-gray-100">
          <div className="bg-blue-50 p-2 rounded-full"><Printer size={14} className="text-blue-500"/></div>
          <span>3. Imprima (Ctrl + P)</span>
        </div>
      </div>
    </div>
  );
};

export default App;
